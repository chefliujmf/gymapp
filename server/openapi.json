{
  "openapi": "3.0.3",
  "info": {
    "title": "Platyplus Coach API",
    "version": "1.2.0",
    "description": "Push planned sessions into a Platyplus account (rich indoor-execution detail). The coach dual-writes: the same `id` goes here AND to the intervals.icu event `external_id`, so Platyplus's Today merges them into one card (no duplicates). Authenticate with the per-user API token from Profile \u2192 Account."
  },
  "servers": [
    {
      "url": "https://platyplus.duckdns.org"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/plan": {
      "post": {
        "summary": "Create or update a planned session (upsert by id)",
        "description": "Idempotent: re-POST the same id to update it.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Plan"
              },
              "examples": {
                "ride": {
                  "value": {
                    "id": "2026-06-20-vo2",
                    "date": "2026-06-20",
                    "sport": "ride",
                    "title": "VO2 5x4",
                    "ftp": 260,
                    "segments": [
                      {
                        "duration": 600,
                        "powerStart": 50,
                        "powerEnd": 60,
                        "label": "warmup"
                      },
                      {
                        "duration": 240,
                        "powerStart": 115,
                        "powerEnd": 115,
                        "label": "VO2"
                      },
                      {
                        "duration": 180,
                        "powerStart": 50,
                        "powerEnd": 50,
                        "label": "recover"
                      }
                    ]
                  }
                },
                "gym": {
                  "value": {
                    "id": "2026-06-21-push",
                    "date": "2026-06-21",
                    "sport": "gym",
                    "title": "Push Day",
                    "rounds": 3,
                    "exercises": [
                      {
                        "name": "Bench Press",
                        "mode": "reps",
                        "sets": 4,
                        "reps": 8,
                        "weight": 60,
                        "rest": 90
                      },
                      {
                        "name": "Plank",
                        "mode": "timed",
                        "seconds": 45,
                        "rest": 15
                      }
                    ]
                  }
                },
                "run": {
                  "value": {
                    "id": "2026-06-22-tempo",
                    "date": "2026-06-22",
                    "sport": "run",
                    "title": "Tempo 3x8",
                    "segments": [
                      {
                        "duration": 600,
                        "powerStart": 70,
                        "powerEnd": 70
                      },
                      {
                        "duration": 480,
                        "powerStart": 95,
                        "powerEnd": 95,
                        "hr": "165"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/plans": {
      "get": {
        "summary": "List planned sessions",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/plan/{id}": {
      "get": {
        "summary": "Get one plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/auth/items": {
      "get": {
        "summary": "List calendar items (meal/mind/note/recovery/supplement) for the signed-in user",
        "description": "Session (cookie) auth \u2014 used by the app UI, not the coach API.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not signed in"
          }
        }
      },
      "post": {
        "summary": "Add/update a calendar item (assign a recipe / mind session to a day)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalItem"
              },
              "examples": {
                "meal": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "meal",
                    "title": "Protein porridge",
                    "refId": "r-5-ingredient-choc-chip-protein-porridge",
                    "mealType": "breakfast",
                    "kcal": 420
                  }
                },
                "mind": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "mind",
                    "title": "Body scan",
                    "refId": "m-body-scan",
                    "minutes": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Not signed in"
          }
        }
      }
    },
    "/auth/items/{id}": {
      "delete": {
        "summary": "Delete a calendar item",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/auth/plans/sync": {
      "post": {
        "summary": "Import intervals.icu-origin planned workouts into Platyplus (Platyplus then owns them)",
        "tags": [
          "plans"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from": { "type": "string", "format": "date" },
                  "to": { "type": "string", "format": "date" }
                },
                "required": ["from", "to"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "{ imported, scanned } or { skipped }" },
          "400": { "description": "from + to required" }
        }
      }
    },
    "/auth/plans/resync": {
      "post": {
        "summary": "Push every Platyplus-origin plan in a window OUT to intervals (dedup-aware re-sync button, #150)",
        "tags": [
          "plans"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from": { "type": "string", "format": "date" },
                  "to": { "type": "string", "format": "date" }
                },
                "required": ["from", "to"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "{ total, created, linked, updated, errors } or { skipped }" },
          "400": { "description": "from + to required" }
        }
      }
    },
    "/auth/plans": {
      "get": {
        "summary": "List the signed-in user's workout plans (session auth)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create/update a workout plan from the UI (also pushes to intervals.icu)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Plan"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/auth/plans/{id}": {
      "delete": {
        "summary": "Delete a workout plan",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/api/items": {
      "get": {
        "summary": "List calendar items (meal/mind/note/recovery/supplement) \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      },
      "post": {
        "summary": "Add/update a calendar item (meal/mind/note/recovery/supplement) \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalItem"
              },
              "examples": {
                "meal": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "meal",
                    "title": "Carb-forward oat bowl",
                    "mealType": "breakfast",
                    "kcal": 520
                  }
                },
                "note": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "note",
                    "notes": "Hydrate well; easy spin only"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad item"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/items/{id}": {
      "delete": {
        "summary": "Delete a calendar item \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/recipes": {
      "get": {
        "summary": "Search recipe library \u2014 coach picks a real meal id for fueling (Bearer)",
        "tags": ["catalog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "q", "in": "query", "schema": { "type": "string" } }, { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "breakfast|lunch|dinner|snack" }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "[{ id, title, category, kcal, protein, minutes }]" } }
      }
    },
    "/api/sessions": {
      "get": {
        "summary": "Search mind/movement library (meditation/yoga/pilates) \u2014 coach picks a session id (Bearer)",
        "tags": ["catalog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "q", "in": "query", "schema": { "type": "string" } }, { "name": "kind", "in": "query", "schema": { "type": "string" }, "description": "meditation|yoga|pilates|breathing" }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "[{ id, title, kind, duration }]" } }
      }
    },
    "/api/notify": {
      "post": {
        "summary": "Post a coach-activity notification to the athlete's bell (Bearer)",
        "description": "Call after creating/adjusting the plan or reviewing a workout, so a short note appears in the athlete's notification center.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title"],
                "properties": {
                  "title": { "type": "string", "description": "one-line summary, e.g. 'Updated your training plan'" },
                  "body": { "type": "string", "description": "optional one-line context" },
                  "items": { "type": "array", "items": { "type": "string" }, "description": "bullets of what changed/was reviewed" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Notification created" },
          "400": { "description": "title is required" }
        }
      }
    },
    "/api/coach-review": {
      "post": {
        "summary": "Coach posts a post-workout REVIEW (Bearer) \u2014 Verdict/Execution/Body/Mind/Next from the cyclingcoach engine",
        "description": "Platyplus is master: the coach writes its COACHCHECK review here (not intervals). Keyed by date (+ optional planId/activityId); re-POST updates. Surfaced in-app.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object", "required": ["date"],
            "properties": {
              "date": { "type": "string", "format": "date" },
              "planId": { "type": "string" }, "activityId": { "type": "string" }, "sport": { "type": "string" },
              "score": { "type": "number", "description": "0-10 execution score" },
              "verdict": { "type": "string" },
              "execution": { "type": "array", "items": { "type": "string" } },
              "body": { "type": "string" },
              "mind": { "type": "object", "properties": { "pattern": { "type": "string" }, "cue": { "type": "string" } } },
              "next": { "type": "string" }, "recovery": { "type": "string" },
              "takeaways": { "type": "array", "items": { "type": "string" }, "description": "short bullets for the Progress card" }
            }
          } } }
        },
        "responses": { "201": { "description": "review stored" }, "400": { "description": "date required" } }
      }
    },
    "/api/exercises": {
      "get": {
        "summary": "Search exercise library \u2014 resolve names to exIds with demo media (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "name fragment, e.g. 'goblet squat'"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "max results (default 20, cap 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of {id,name,category,image,video}",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Exercise"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/auth/strava/status": {
      "get": {
        "summary": "Strava connection status (configured + scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "status"
          }
        }
      }
    },
    "/auth/profile/athlete": {
      "get": {
        "summary": "Get the signed-in user's athlete coaching profile (engine-native markdown)",
        "tags": [
          "profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "{ profile, updatedAt }"
          }
        }
      },
      "put": {
        "summary": "Replace the signed-in user's athlete coaching profile (markdown, max 60k chars)",
        "tags": [
          "profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "profile": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "{ profile, updatedAt }"
          },
          "413": {
            "description": "profile too long"
          }
        }
      }
    },
    "/auth/activity/complete": {
      "post": {
        "summary": "A Platyplus-recorded workout finished → fan out to intervals (match-first, #122/#123)",
        "description": "Keeps the local Platyplus copy; checks intervals for a matching device activity (don't duplicate), else uploads a TCX built from the sample stream. No-op (local-only) when intervals isn't connected.",
        "tags": ["activity"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["date", "sport"],
          "properties": {
            "sport": { "type": "string" }, "title": { "type": "string" },
            "date": { "type": "string", "format": "date" }, "startIso": { "type": "string" },
            "durationSec": { "type": "number" },
            "samples": { "type": "array", "items": { "type": "object", "properties": { "t": { "type": "number" }, "power": { "type": "number" }, "cadence": { "type": "number" }, "hr": { "type": "number" } } } }
          }
        } } } },
        "responses": { "200": { "description": "status: uploaded | matched | local-only | no-stream | error" } }
      }
    },
    "/auth/activity/parse": {
      "post": {
        "summary": "Parse an uploaded activity file (.fit/.gpx/.tcx) → summary + GPS track (#129)",
        "description": "Pure parse for manual-entry prefill — no storage, no intervals call. Returns sport, start, duration, distance, avg HR/power, elevation, calories, and a downsampled GPS track (hasGps=false when the file has no positions).",
        "tags": ["activity"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["b64"],
          "properties": { "name": { "type": "string" }, "b64": { "type": "string", "description": "base64 of the file" } }
        } } } },
        "responses": { "200": { "description": "parsed summary + track" }, "413": { "description": "file too large (25MB max)" }, "422": { "description": "unparseable / unsupported file" } }
      }
    },
    "/auth/activity/manual": {
      "post": {
        "summary": "Manual activity entry → fan out to intervals match-first (#129)",
        "description": "Local Platyplus copy is saved via /auth/logs; this fans out to intervals: uploads the raw file (best fidelity) or a summary TCX built from the entered totals. No-op (local-only) when intervals isn't connected.",
        "tags": ["activity"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["date", "sport"],
          "properties": {
            "sport": { "type": "string" }, "title": { "type": "string" },
            "date": { "type": "string", "format": "date" }, "startIso": { "type": "string" },
            "durationSec": { "type": "number" }, "distanceM": { "type": "number" },
            "avgHr": { "type": "number" }, "avgPower": { "type": "number" },
            "file": { "type": "object", "properties": { "name": { "type": "string" }, "b64": { "type": "string" } } }
          }
        } } } },
        "responses": { "200": { "description": "status: uploaded | matched | local-only | error" } }
      }
    },
    "/auth/promote-prod": {
      "post": {
        "summary": "Admin: promote dev → prod by opening/reusing a dev→main PR + enabling auto-merge (uses GH_PROMOTE_TOKEN; Contents+PRs write, no actions:write needed).",
        "tags": ["admin"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "PR opened/reused + auto-merge enabled (merges when the build check passes)" }, "409": { "description": "nothing to promote — prod already up to date" }, "503": { "description": "GH_PROMOTE_TOKEN not configured" }, "502": { "description": "GitHub API error" } }
      }
    },
    "/auth/checkin": {
      "post": {
        "summary": "Upsert today's daily check-in (energy/sleep/soreness, each 1-5; soreness 5=very sore). Optional `auto` {energy,sleep,freshness} records the auto scores shown → personal calibration (#207 Phase 2b)",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "the saved check-in" } }
      }
    },
    "/auth/checkins": {
      "get": {
        "summary": "List the user's daily check-ins in a date range",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "from", "in": "query", "schema": { "type": "string", "format": "date" } }, { "name": "to", "in": "query", "schema": { "type": "string", "format": "date" } }],
        "responses": { "200": { "description": "check-ins" } }
      }
    },
    "/auth/readiness": {
      "get": {
        "summary": "Auto-derived readiness (Sleep/Freshness/Energy 1-5) from 60d intervals wellness + personal baselines (#195)",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "date", "in": "query", "schema": { "type": "string", "format": "date" } }],
        "responses": { "200": { "description": "{ connected, sleep, freshness, energy (null on cold start), calibration (learned per-dim offsets, #207 Phase 2b), baseline, today }" } }
      }
    },
    "/auth/readiness-forecast": {
      "get": {
        "summary": "Forecast a FUTURE day's expected Freshness from planned load (projects CTL/ATL→Form). Only Freshness is forecastable ahead (#223)",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "date", "in": "query", "required": true, "schema": { "type": "string", "format": "date" } }],
        "responses": { "200": { "description": "{ connected, future, available, date, daysOut, form, freshness (1-5), acwr, totalPlannedLoad, plannedDays }" } }
      }
    },
    "/auth/intervals/athlete": {
      "get": {
        "summary": "Pull the athlete's intervals.icu per-sport settings (ftp/maxHr/lthr/threshold_pace) + weight, mapped to Platyplus stats (#210)",
        "tags": ["profile"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ connected, sportSettings:{cycling,running,swimming}, weight, source }" } }
      }
    },
    "/auth/intervals/run-estimate": {
      "get": {
        "summary": "Estimate the runner's threshold pace from intervals' pace curve (Critical Speed) — running eFTP, a suggestion to apply/override (#215)",
        "tags": ["profile"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ available, thresholdPace (sec/km), criticalSpeed, r2, source }" } }
      }
    },
    "/auth/intervals/run-volume": {
      "get": {
        "summary": "Running endurance base (longest run + avg weekly km, last 6 wks) for the marathon-realism durability range (#216)",
        "tags": ["profile"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "{ available, longestKm, weeklyKm, runs, windowDays }" } }
      }
    },
    "/auth/sport-stat": {
      "put": {
        "summary": "Set a per-sport stat and TWO-WAY sync it to intervals.icu (auto-push; modifies only that sport's sportSettings entry, custom fields untouched) (#210)",
        "tags": ["profile"],
        "security": [{ "cookieAuth": [] }],
        "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "group": { "type": "string", "enum": ["cycling", "running", "swimming"] }, "ftp": { "type": "number" }, "maxHr": { "type": "number" }, "lthr": { "type": "number" }, "thresholdPace": { "type": "number", "description": "running sec/km, swim sec/100m" }, "runVdot": { "type": "number" } } } } } },
        "responses": { "200": { "description": "updated public user + { synced, pushError }" } }
      }
    },
    "/api/checkins": {
      "get": {
        "summary": "Coach reads the athlete's daily check-ins (energy/sleep/soreness) — recovery signal",
        "tags": ["checkin"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "check-ins" } }
      }
    },
    "/auth/strava/activities": {
      "get": {
        "summary": "Recent Strava activities (read; needs activity:read_all scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent Strava activities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Strava error (e.g. token scope)"
          }
        }
      }
    },
    "/api/intervals/wellness": {
      "get": {
        "summary": "Read-through the user's recent intervals.icu wellness (Fitness/CTL, Fatigue/ATL, Form, resting HR, HRV, sleep, weight). Live, not stored. { connected:false } if unconnected.",
        "tags": ["intervals"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "days", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ connected, wellness[] }" } }
      }
    },
    "/api/intervals/activities": {
      "get": {
        "summary": "Read-through the user's recently completed intervals.icu activities (duration/distance/HR/power/Load/RPE, indoor vs outdoor). Live, not stored.",
        "tags": ["intervals"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "days", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ connected, activities[] }" } }
      }
    },
    "/api/strava/activities": {
      "get": {
        "summary": "Recent Strava activities (Bearer; needs activity:read_all scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent Strava activities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Strava error (e.g. token scope)"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Per-user API token (Profile \u2192 Account \u2192 API token)."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "gymapp_sess",
        "description": "Session cookie from /auth/login or passkey login (browser/UI only)."
      }
    },
    "schemas": {
      "CalItem": {
        "type": "object",
        "required": [
          "date",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "YYYY-MM-DD"
          },
          "type": {
            "type": "string",
            "enum": [
              "meal",
              "mind",
              "note"
            ]
          },
          "title": {
            "type": "string"
          },
          "refId": {
            "type": "string",
            "description": "catalog id of the recipe / mind session / etc."
          },
          "mealType": {
            "type": "string"
          },
          "kcal": {
            "type": "integer"
          },
          "minutes": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "Segment": {
        "type": "object",
        "description": "One ride/run interval. power is % of FTP (ride) or % of threshold (run).",
        "required": [
          "duration",
          "powerStart",
          "powerEnd"
        ],
        "properties": {
          "duration": {
            "type": "integer",
            "description": "seconds"
          },
          "powerStart": {
            "type": "number",
            "description": "% FTP/threshold at start (ramp start)"
          },
          "powerEnd": {
            "type": "number",
            "description": "% at end (= start for steady)"
          },
          "label": {
            "type": "string"
          },
          "hr": {
            "type": "string",
            "description": "target bpm"
          }
        }
      },
      "Exercise": {
        "type": "object",
        "required": [
          "name",
          "mode"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "exId": {
            "type": "string",
            "description": "optional Platyplus library id for the demo video"
          },
          "mode": {
            "type": "string",
            "enum": [
              "timed",
              "reps"
            ]
          },
          "seconds": {
            "type": "integer",
            "description": "for mode=timed"
          },
          "sets": {
            "type": "integer",
            "description": "for mode=reps"
          },
          "reps": {
            "type": "integer",
            "description": "for mode=reps"
          },
          "weight": {
            "type": "number"
          },
          "rest": {
            "type": "integer",
            "description": "seconds between sets"
          }
        }
      },
      "Plan": {
        "type": "object",
        "required": [
          "id",
          "date",
          "sport",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Shared id \u2014 also set as the intervals.icu event external_id."
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "YYYY-MM-DD"
          },
          "sport": {
            "type": "string",
            "enum": [
              "gym",
              "ride",
              "run"
            ]
          },
          "title": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "ftp": {
            "type": "number",
            "description": "ride only; defaults to athlete FTP if omitted"
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Segment"
            },
            "description": "ride/run"
          },
          "rounds": {
            "type": "integer",
            "description": "gym only"
          },
          "exercises": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Exercise"
            },
            "description": "gym only"
          }
        }
      }
    }
  }
}