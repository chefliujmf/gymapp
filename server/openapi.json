{
  "openapi": "3.0.3",
  "info": {
    "title": "Platyplus Coach API",
    "version": "1.2.0",
    "description": "Push planned sessions into a Platyplus account (rich indoor-execution detail). The coach dual-writes: the same `id` goes here AND to the intervals.icu event `external_id`, so Platyplus's Today merges them into one card (no duplicates). Authenticate with the per-user API token from Profile \u2192 Account."
  },
  "servers": [
    {
      "url": "https://platyplus.duckdns.org"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/plan": {
      "post": {
        "summary": "Create or update a planned session (upsert by id)",
        "description": "Idempotent: re-POST the same id to update it.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Plan"
              },
              "examples": {
                "ride": {
                  "value": {
                    "id": "2026-06-20-vo2",
                    "date": "2026-06-20",
                    "sport": "ride",
                    "title": "VO2 5x4",
                    "ftp": 260,
                    "segments": [
                      {
                        "duration": 600,
                        "powerStart": 50,
                        "powerEnd": 60,
                        "label": "warmup"
                      },
                      {
                        "duration": 240,
                        "powerStart": 115,
                        "powerEnd": 115,
                        "label": "VO2"
                      },
                      {
                        "duration": 180,
                        "powerStart": 50,
                        "powerEnd": 50,
                        "label": "recover"
                      }
                    ]
                  }
                },
                "gym": {
                  "value": {
                    "id": "2026-06-21-push",
                    "date": "2026-06-21",
                    "sport": "gym",
                    "title": "Push Day",
                    "rounds": 3,
                    "exercises": [
                      {
                        "name": "Bench Press",
                        "mode": "reps",
                        "sets": 4,
                        "reps": 8,
                        "weight": 60,
                        "rest": 90
                      },
                      {
                        "name": "Plank",
                        "mode": "timed",
                        "seconds": 45,
                        "rest": 15
                      }
                    ]
                  }
                },
                "run": {
                  "value": {
                    "id": "2026-06-22-tempo",
                    "date": "2026-06-22",
                    "sport": "run",
                    "title": "Tempo 3x8",
                    "segments": [
                      {
                        "duration": 600,
                        "powerStart": 70,
                        "powerEnd": 70
                      },
                      {
                        "duration": 480,
                        "powerStart": 95,
                        "powerEnd": 95,
                        "hr": "165"
                      }
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/plans": {
      "get": {
        "summary": "List planned sessions",
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/plan/{id}": {
      "get": {
        "summary": "Get one plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Plan",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Plan"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a plan",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/auth/items": {
      "get": {
        "summary": "List calendar items (meal/mind/note) for the signed-in user",
        "description": "Session (cookie) auth \u2014 used by the app UI, not the coach API.",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Not signed in"
          }
        }
      },
      "post": {
        "summary": "Add/update a calendar item (assign a recipe / mind session to a day)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalItem"
              },
              "examples": {
                "meal": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "meal",
                    "title": "Protein porridge",
                    "refId": "r-5-ingredient-choc-chip-protein-porridge",
                    "mealType": "breakfast",
                    "kcal": 420
                  }
                },
                "mind": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "mind",
                    "title": "Body scan",
                    "refId": "m-body-scan",
                    "minutes": 10
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Not signed in"
          }
        }
      }
    },
    "/auth/items/{id}": {
      "delete": {
        "summary": "Delete a calendar item",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/auth/plans/sync": {
      "post": {
        "summary": "Import intervals.icu-origin planned workouts into Platyplus (Platyplus then owns them)",
        "tags": [
          "plans"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "from": { "type": "string", "format": "date" },
                  "to": { "type": "string", "format": "date" }
                },
                "required": ["from", "to"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "{ imported, scanned } or { skipped }" },
          "400": { "description": "from + to required" }
        }
      }
    },
    "/auth/plans": {
      "get": {
        "summary": "List the signed-in user's workout plans (session auth)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Plan"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create/update a workout plan from the UI (also pushes to intervals.icu)",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Plan"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          }
        }
      }
    },
    "/auth/plans/{id}": {
      "delete": {
        "summary": "Delete a workout plan",
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          }
        }
      }
    },
    "/api/items": {
      "get": {
        "summary": "List calendar items (meal/mind/note) \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          },
          {
            "name": "to",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            },
            "description": "YYYY-MM-DD inclusive"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/CalItem"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      },
      "post": {
        "summary": "Add/update a calendar item (meal/mind/note) \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CalItem"
              },
              "examples": {
                "meal": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "meal",
                    "title": "Carb-forward oat bowl",
                    "mealType": "breakfast",
                    "kcal": 520
                  }
                },
                "note": {
                  "value": {
                    "date": "2026-06-22",
                    "type": "note",
                    "notes": "Hydrate well; easy spin only"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated"
          },
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad item"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/items/{id}": {
      "delete": {
        "summary": "Delete a calendar item \u2014 coach API (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted"
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/api/recipes": {
      "get": {
        "summary": "Search recipe library \u2014 coach picks a real meal id for fueling (Bearer)",
        "tags": ["catalog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "q", "in": "query", "schema": { "type": "string" } }, { "name": "category", "in": "query", "schema": { "type": "string" }, "description": "breakfast|lunch|dinner|snack" }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "[{ id, title, category, kcal, protein, minutes }]" } }
      }
    },
    "/api/sessions": {
      "get": {
        "summary": "Search mind/movement library (meditation/yoga/pilates) \u2014 coach picks a session id (Bearer)",
        "tags": ["catalog"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "q", "in": "query", "schema": { "type": "string" } }, { "name": "kind", "in": "query", "schema": { "type": "string" }, "description": "meditation|yoga|pilates|breathing" }, { "name": "limit", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "[{ id, title, kind, duration }]" } }
      }
    },
    "/api/exercises": {
      "get": {
        "summary": "Search exercise library \u2014 resolve names to exIds with demo media (Bearer)",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "name fragment, e.g. 'goblet squat'"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "max results (default 20, cap 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of {id,name,category,image,video}",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Exercise"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid API token"
          }
        }
      }
    },
    "/auth/strava/status": {
      "get": {
        "summary": "Strava connection status (configured + scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "status"
          }
        }
      }
    },
    "/auth/profile/athlete": {
      "get": {
        "summary": "Get the signed-in user's athlete coaching profile (engine-native markdown)",
        "tags": [
          "profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "{ profile, updatedAt }"
          }
        }
      },
      "put": {
        "summary": "Replace the signed-in user's athlete coaching profile (markdown, max 60k chars)",
        "tags": [
          "profile"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "profile": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "{ profile, updatedAt }"
          },
          "413": {
            "description": "profile too long"
          }
        }
      }
    },
    "/auth/checkin": {
      "post": {
        "summary": "Upsert today's daily check-in (energy/sleep/soreness, each 1-5; soreness 5=very sore)",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "responses": { "200": { "description": "the saved check-in" } }
      }
    },
    "/auth/checkins": {
      "get": {
        "summary": "List the user's daily check-ins in a date range",
        "tags": ["checkin"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [{ "name": "from", "in": "query", "schema": { "type": "string", "format": "date" } }, { "name": "to", "in": "query", "schema": { "type": "string", "format": "date" } }],
        "responses": { "200": { "description": "check-ins" } }
      }
    },
    "/api/checkins": {
      "get": {
        "summary": "Coach reads the athlete's daily check-ins (energy/sleep/soreness) — recovery signal",
        "tags": ["checkin"],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "check-ins" } }
      }
    },
    "/auth/strava/activities": {
      "get": {
        "summary": "Recent Strava activities (read; needs activity:read_all scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent Strava activities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Strava error (e.g. token scope)"
          }
        }
      }
    },
    "/api/intervals/wellness": {
      "get": {
        "summary": "Read-through the user's recent intervals.icu wellness (Fitness/CTL, Fatigue/ATL, Form, resting HR, HRV, sleep, weight). Live, not stored. { connected:false } if unconnected.",
        "tags": ["intervals"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "days", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ connected, wellness[] }" } }
      }
    },
    "/api/intervals/activities": {
      "get": {
        "summary": "Read-through the user's recently completed intervals.icu activities (duration/distance/HR/power/Load/RPE, indoor vs outdoor). Live, not stored.",
        "tags": ["intervals"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "days", "in": "query", "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "{ connected, activities[] }" } }
      }
    },
    "/api/strava/activities": {
      "get": {
        "summary": "Recent Strava activities (Bearer; needs activity:read_all scope)",
        "tags": [
          "strava"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent Strava activities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "502": {
            "description": "Strava error (e.g. token scope)"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Per-user API token (Profile \u2192 Account \u2192 API token)."
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "gymapp_sess",
        "description": "Session cookie from /auth/login or passkey login (browser/UI only)."
      }
    },
    "schemas": {
      "CalItem": {
        "type": "object",
        "required": [
          "date",
          "type"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "YYYY-MM-DD"
          },
          "type": {
            "type": "string",
            "enum": [
              "meal",
              "mind",
              "note"
            ]
          },
          "title": {
            "type": "string"
          },
          "refId": {
            "type": "string",
            "description": "catalog id of the recipe / mind session / etc."
          },
          "mealType": {
            "type": "string"
          },
          "kcal": {
            "type": "integer"
          },
          "minutes": {
            "type": "integer"
          },
          "notes": {
            "type": "string"
          }
        }
      },
      "Segment": {
        "type": "object",
        "description": "One ride/run interval. power is % of FTP (ride) or % of threshold (run).",
        "required": [
          "duration",
          "powerStart",
          "powerEnd"
        ],
        "properties": {
          "duration": {
            "type": "integer",
            "description": "seconds"
          },
          "powerStart": {
            "type": "number",
            "description": "% FTP/threshold at start (ramp start)"
          },
          "powerEnd": {
            "type": "number",
            "description": "% at end (= start for steady)"
          },
          "label": {
            "type": "string"
          },
          "hr": {
            "type": "string",
            "description": "target bpm"
          }
        }
      },
      "Exercise": {
        "type": "object",
        "required": [
          "name",
          "mode"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "exId": {
            "type": "string",
            "description": "optional Platyplus library id for the demo video"
          },
          "mode": {
            "type": "string",
            "enum": [
              "timed",
              "reps"
            ]
          },
          "seconds": {
            "type": "integer",
            "description": "for mode=timed"
          },
          "sets": {
            "type": "integer",
            "description": "for mode=reps"
          },
          "reps": {
            "type": "integer",
            "description": "for mode=reps"
          },
          "weight": {
            "type": "number"
          },
          "rest": {
            "type": "integer",
            "description": "seconds between sets"
          }
        }
      },
      "Plan": {
        "type": "object",
        "required": [
          "id",
          "date",
          "sport",
          "title"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "Shared id \u2014 also set as the intervals.icu event external_id."
          },
          "date": {
