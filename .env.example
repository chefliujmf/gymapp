# Platyplus env vars — copy real values into auth.env (prod/QA, gitignored) or
# .secrets/strava.env (local dev). NEVER put real secrets in this file.

# --- Strava integration ---
# App-level creds from your Strava API application (Settings → API).
STRAVA_CLIENT_ID=replace_me
STRAVA_CLIENT_SECRET=replace_me
# Per-user durable token (the server mints short-lived access tokens from it).
# Needs `activity:write` scope to PUSH workouts to Strava; `read` only pulls.
STRAVA_REFRESH_TOKEN=replace_me

TAILSCALE_TOKEN=tskey-REPLACE_ME  # reusable auth key — REAL value lives in .secrets/tailscale.env (gitignored)