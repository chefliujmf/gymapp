{
  "name": "gymapp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal self-hosted fitness app (Centr-style) — installable PWA",
  "scripts": {
    "dev": "concurrently -k --restart-tries 20 --restart-after 1000 -n api,web -c green,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "bash scripts/dev-api.sh",
    "dev:full": "npm run dev",
    "build": "node scripts/engine-name-gate.mjs && node scripts/check-theme.mjs && node scripts/check-undef.mjs && node scripts/build-catalog.mjs && node scripts/build-backlog.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "seed:centr": "node scripts/seed-from-centr.mjs",
    "build:catalog": "node scripts/build-catalog.mjs",
    "deploy": "bash scripts/deploy.sh",
    "build:app": "node scripts/engine-name-gate.mjs && node scripts/check-theme.mjs && node scripts/check-undef.mjs && node scripts/build-backlog.mjs && tsc -b && vite build && node scripts/publish-items.mjs",
    "sync:catalog": "bash scripts/sync-catalog.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:backlog": "node scripts/build-backlog.mjs"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.9"
  }
}
