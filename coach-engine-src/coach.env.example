# Copy to .secrets/coach.env for local Codex/CLI runs.
# Keep the real .secrets/coach.env file out of git.

export INTERVALS_ICU_API_KEY="replace_me"
export INTERVALS_ICU_ATHLETE_ID="i28814"

# Optional Centr collector credentials.
export CENTR_EMAIL="replace_me"
export CENTR_PASSWORD="replace_me"

# Future Strava automation, if enabled.
export STRAVA_CLIENT_ID="replace_me"
export STRAVA_CLIENT_SECRET="replace_me"
export STRAVA_REFRESH_TOKEN="replace_me"

# Platyplus Coach API (prod) — coach authors plans here; fans out to intervals.icu -> Wahoo.
# Per-user token from Platyplus Profile -> Account.
export PLATYPLUS_BASE="https://platyplus.duckdns.org"
export PLATYPLUS_TOKEN="replace_me"
